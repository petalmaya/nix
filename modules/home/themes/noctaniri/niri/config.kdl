// Niri configuration for Noctaniri
output "HDMI-A-1" {
    mode "1680x1050"
    position x=0 y=0
}

output "eDP-1" {
    position x=1680 y=0
}

input {
    touchpad {
        tap
        natural-scroll
    }
    touch {
        map-to-output "eDP-1"
    }
}

layer-rule {
    match namespace="^noctalia-backdrop$"
    place-within-backdrop true
}

// Optionally, disable workspace shadows in the overview.
overview {
    workspace-shadow {
        off
    }
}

layout {
    gaps 12
    center-focused-column "never"
    background-color "transparent"
    preset-column-widths {
        proportion 0.333
        proportion 0.5
        proportion 0.667
        proportion 1.0
    }
    default-column-width { proportion 0.5; }

    // Border colours match sunset colors (focused active gradient from crimson #9E3B4B to golden yellow #F9C567, inactive dark rust #5C2518)
    focus-ring {
        width 3
    }
    border {
        off
    }
}

prefer-no-csd

window-rule {
    match app-id="^(eog|sxiv|feh|mpv|vlc|file-roller|xarchiver)$"
    open-floating true
}
window-rule {
    match app-id="org.gnome.Nautilus" title=".*Progress.*"
    open-floating true
}
window-rule {
    match app-id="org.gnome.Nautilus" title=".*Replace.*"
    open-floating true
}

// Rounded corners for niri windows
window-rule {
    geometry-corner-radius 12
    clip-to-geometry true
}

cursor {
    xcursor-theme "capitaine-cursors"
    xcursor-size 24
}

environment {
    XDG_CURRENT_DESKTOP "niri"
    PYTHONIOENCODING "utf-8"
}

binds {
    // Terminal / launcher
    "Mod+Return"      { spawn "foot"; }
    "Mod+D"           { spawn "noctalia" "msg" "panel-toggle" "launcher"; }

    // Screenshot
    "Print"           { spawn "noctalia" "msg" "screenshot-region"; }
    "Mod+Print"       { spawn "sh" "-c" "grim -g \"$(slurp)\" ~/Pictures/$(date +%Y-%m-%d_%H-%m-%s).png"; }

    // Lock
    "Mod+L"           { spawn "noctalia" "msg" "session" "lock"; }

    // Apps
    "Mod+W"           { spawn "zen-twilight"; }
    "Mod+E"           { spawn "nautilus"; }
    "Mod+M"           { spawn "foot" "-e" "rmpc"; }
    "Mod+N"           { spawn "mpv" "--player-operation-mode=pseudo-gui"; }

    // Audio / brightness
    "XF86AudioRaiseVolume"    { spawn "pactl" "set-sink-volume" "@DEFAULT_SINK@" "+5%"; }
    "XF86AudioLowerVolume"    { spawn "pactl" "set-sink-volume" "@DEFAULT_SINK@" "-5%"; }
    "XF86AudioMute"           { spawn "pactl" "set-sink-mute" "@DEFAULT_SINK@" "toggle"; }
    "XF86MonBrightnessUp"     { spawn "brightnessctl" "set" "+5%"; }
    "XF86MonBrightnessDown"   { spawn "brightnessctl" "set" "5%-"; }

    // Window management
    "Mod+C"           { close-window; }
    "Alt+F4"          { close-window; }

    "Mod+F"           { maximize-column; }
    "Mod+Shift+F"     { fullscreen-window; }
    "Mod+Space"       { toggle-window-floating; }
    "Mod+Shift+Space" { switch-focus-between-floating-and-tiling; }

    // Focus movement (sway-like arrow keys)
    "Mod+Left"        { focus-column-left; }
    "Mod+Right"       { focus-column-right; }
    "Mod+Up"          { focus-window-up; }
    "Mod+Down"        { focus-window-down; }

    // Move columns / windows (sway-like)
    "Mod+Shift+Left"  { move-column-left; }
    "Mod+Shift+Right" { move-column-right; }
    "Mod+Shift+Up"    { move-window-up; }
    "Mod+Shift+Down"  { move-window-down; }

    // H and V window actions (familiar to sway split h and split v)
    "Mod+H"           { expel-window-from-column; }
    "Mod+V"           { consume-window-into-column; }
    "Mod+BracketLeft"  { consume-or-expel-window-left; }
    "Mod+BracketRight" { consume-or-expel-window-right; }

    // Workspaces
    "Mod+Control+Right" { focus-workspace-down; }
    "Mod+Control+Left"  { focus-workspace-up; }
    "Mod+Control+Shift+Right" { move-column-to-workspace-down; }
    "Mod+Control+Shift+Left"  { move-column-to-workspace-up; }
    "Mod+Ctrl+Page_Down"      { move-column-to-workspace-down; }
    "Mod+Ctrl+Page_Up"        { move-column-to-workspace-up; }
    "Mod+1"             { focus-workspace 1; }
    "Mod+2"             { focus-workspace 2; }
    "Mod+3"             { focus-workspace 3; }
    "Mod+4"             { focus-workspace 4; }
    "Mod+5"             { focus-workspace 5; }
    "Mod+6"             { focus-workspace 6; }
    "Mod+Shift+1"       { move-column-to-workspace 1; }
    "Mod+Shift+2"       { move-column-to-workspace 2; }
    "Mod+Shift+3"       { move-column-to-workspace 3; }
    "Mod+Shift+4"       { move-column-to-workspace 4; }
    "Mod+Shift+5"       { move-column-to-workspace 5; }
    "Mod+Shift+6"       { move-column-to-workspace 6; }

    // Column sizing
    "Mod+Minus" { set-column-width "-10%"; }
    "Mod+Equal" { set-column-width "+10%"; }
    "Mod+R"     { switch-preset-column-width; }

    // Quit / reload / overview
    "Mod+Q"           { quit; }
    "Mod+Shift+C"     { spawn "niri-msg" "reload"; }
    "Mod+O"           { toggle-overview; }

    // Show keybind overlay
    "Mod+Shift+Slash" { show-hotkey-overlay; }
}

// Include the dynamic color template generated by Noctalia v5 at runtime
include optional=true "noctalia.kdl"