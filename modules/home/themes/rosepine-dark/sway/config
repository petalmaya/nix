# Sway configuration for Rosepine Dark
default_border pixel 2
gaps inner 0
gaps outer 0
smart_gaps off

# Fonts
font pango:Courier Prime 11

# Output displays positions
output HDMI-A-1 pos 0 0
output eDP-1 pos 1440 0

# Touchscreen Input
input "3823:49229:eGalax_Inc._eGalaxTouch_EXC3000-0367-46.00.00" {
    map_to_output eDP-1
}

# Window rules and styling
for_window [app_id="(?i)eog|sxiv|feh|mpv|vlc|file-roller|xarchiver"] floating enable, focus
for_window [class="(?i)eog|sxiv|feh|mpv|vlc|file-roller|xarchiver"] floating enable, focus
for_window [window_role="dialog"] floating enable
for_window [window_role="pop-up"] floating enable
for_window [window_type="dialog"] floating enable
for_window [window_type="menu"] floating enable
for_window [app_id="thunar" title="File Operation Progress"] floating enable
for_window [app_id="thunar" title="Confirm to replace files"] floating enable, sticky enable, focus

# Colors
# Rosepine Dark color scheme
# base: #191724  surface: #1f1d2e  overlay: #26233a
# love: #eb6f92  gold: #f6c177  rose: #ebbcba
# pine: #31748f  foam: #9ccfd8  iris: #c4a7e7
# text: #e0def4  subtle: #908caa  muted: #6e6a86
# class                 border  backgr. text    indicator child_border
client.focused          #eb6f92 #1f1d2e #e0def4 #9ccfd8   #eb6f92
client.focused_inactive #26233a #1f1d2e #908caa #26233a   #26233a
client.unfocused        #191724 #191724 #6e6a86 #191724   #191724
client.urgent           #f6c177 #f6c177 #191724 #f6c177   #f6c177
client.placeholder      #191724 #191724 #e0def4 #191724   #191724
client.background       #191724

# Keybindings
bindsym Mod4+Return exec foot
bindsym Mod4+d exec wofi --show drun --allow-images
bindsym Mod4+k exec $HOME/.local/bin/wl-kaomoji
bindsym Mod4+Shift+c reload

bindsym Print exec grim -g "$(slurp)" ~/Pictures/$(date +%Y-%m-%d_%H-%m-%s).png
bindsym Mod4+l exec swaylock --color 191724 --ring-color eb6f92 --key-hl-color f6c177 --text-color e0def4
bindsym Mod4+w exec zen-twilight
bindsym Mod4+e exec foot -e yazi
bindsym Mod4+m exec foot -e rmpc
bindsym Mod4+n exec mpv --player-operation-mode=pseudo-gui

bindsym XF86AudioRaiseVolume exec swayosd-client --output-volume raise
bindsym XF86AudioLowerVolume exec swayosd-client --output-volume lower
bindsym XF86AudioMute exec swayosd-client --output-volume mute-toggle
bindsym XF86MonBrightnessUp exec swayosd-client --brightness raise
bindsym XF86MonBrightnessDown exec swayosd-client --brightness lower

bindsym Mod4+c kill
bindsym Mod1+F4 kill

bindsym Mod4+h split h
bindsym Mod4+v split v
bindsym Mod4+s layout toggle split
bindsym Mod4+f fullscreen toggle
bindsym Mod4+space floating toggle
bindsym Mod4+Shift+space focus mode_toggle

bindsym Mod4+Control+Right workspace next
bindsym Mod4+Control+Left workspace prev
bindsym Mod4+1 workspace 1:1
bindsym Mod4+2 workspace 2:2
bindsym Mod4+3 workspace 3:3
bindsym Mod4+4 workspace 4:4
bindsym Mod4+5 workspace 5:5
bindsym Mod4+6 workspace 6:6

bindsym Mod4+Shift+1 move container to workspace 1:1
bindsym Mod4+Shift+2 move container to workspace 2:2
bindsym Mod4+Shift+3 move container to workspace 3:3
bindsym Mod4+Shift+4 move container to workspace 4:4
bindsym Mod4+Shift+5 move container to workspace 5:5
bindsym Mod4+Shift+6 move container to workspace 6:6

# Focus movement (arrow keys)
bindsym Mod4+Left focus left
bindsym Mod4+Down focus down
bindsym Mod4+Up focus up
bindsym Mod4+Right focus right

# Move window (arrow keys)
bindsym Mod4+Shift+Left move left
bindsym Mod4+Shift+Down move down
bindsym Mod4+Shift+Up move up
bindsym Mod4+Shift+Right move right

bindsym Mod4+BackSpace exec swaymsg reload
bindsym Mod4+q exec swaynag -t warning -m 'Really exit?' -b 'Yes' 'swaymsg exit'
bindsym Mod4+r mode resize

# Resize Mode
mode "resize" {
    bindsym Left resize shrink width 5 px or 5 ppt
    bindsym Down resize grow height 5 px or 5 ppt
    bindsym Up resize shrink height 5 px or 5 ppt
    bindsym Right resize grow width 5 px or 5 ppt
    bindsym Return mode default
    bindsym Escape mode default
}

# Autostart applications
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway
exec systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
exec keepassxc --minimized
exec mako
exec waybar
